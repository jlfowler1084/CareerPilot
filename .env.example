# CareerPilot — Environment Variables
# Copy this file to .env and fill in your actual values.

# Anthropic API
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Google OAuth2 (from Google Cloud Console > Credentials > OAuth 2.0 Client)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:8080

# Google API Scopes (comma-separated if multiple)
GMAIL_SCOPES=https://www.googleapis.com/auth/gmail.modify
CALENDAR_SCOPES=https://www.googleapis.com/auth/calendar

# SQLite database path (relative to project root or absolute)
DB_PATH=data/careerpilot.db

# Timezone
TIMEZONE=America/Indiana/Indianapolis

# Claude model selection (API Cost Governance)
MODEL_HAIKU=claude-haiku-4-5-20251001
MODEL_SONNET=claude-sonnet-4-6
MODEL_OPUS=claude-opus-4-6

# Local LLM Router — chat endpoint (CAR-142)
# vLLM instance serving the chat/instruct model (e.g. Qwen3-32B-Instruct on port 8000)
CAREERPILOT_LLM_LOCAL_BASE_URL=http://localhost:8000/v1
CAREERPILOT_LLM_LOCAL_MODEL_CHAT=Qwen/Qwen3-32B-Instruct

# Local LLM Router — embeddings endpoint (separate vLLM instance, different port)
# vLLM instance serving the embedding model (Qwen3-Embedding-8B on port 8001)
CAREERPILOT_LLM_LOCAL_EMBED_BASE_URL=http://localhost:8001/v1
CAREERPILOT_LLM_LOCAL_MODEL_EMBED=Qwen/Qwen3-Embedding-8B

# API key for local vLLM (leave empty — vLLM doesn't require one by default)
CAREERPILOT_LLM_LOCAL_API_KEY=

# Force all tasks to a specific provider: "local" | "claude" | "" (default = task map)
CAREERPILOT_LLM_FORCE=

# Max Claude fallback calls in a rolling 24h window (0 = unlimited)
CAREERPILOT_LLM_FALLBACK_BUDGET_PER_DAY=50

# Set to 1 in scheduled/unattended environments (suppresses interactive PII prompts)
CAREERPILOT_UNATTENDED=0
